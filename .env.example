MONGODB_URI=mongodb://localhost:27017/focus-hub
BETTER_AUTH_SECRET=your-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:3000

# SMTP (Gmail — use an App Password, not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Focus ASTU <your-email@gmail.com>"

# Supabase (Storage for post images)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chapa Payment Gateway
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxx
